# ──────────────────────────────────────────────────────────────────────────────
# TVIGILO Cam Advisor — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Map Provider ─────────────────────────────────────────────────────────────
# Google Maps key — used for Geocoding, Static Maps, and Places Autocomplete.
# Enable these three APIs in your GCP project:
#   1. Geocoding API
#   2. Maps Static API
#   3. Places API  (for address autocomplete suggestions)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Active provider ("google" or "mapbox"). Defaults to "google".
MAP_PROVIDER=google

# ─── Image Settings ────────────────────────────────────────────────────────────
# Satellite image size in pixels (max 640 for Google Maps free tier)
SATELLITE_WIDTH=640
SATELLITE_HEIGHT=640

# Zoom level for satellite view.
# 20 = tight focus on a single property (recommended).
# 19 = wider neighbourhood context.
SATELLITE_ZOOM=20

# Centre-crop factor applied after satellite fetch (0.0–1.0).
# Smaller = tighter framing of the property. 1 = no crop.
# 0.78 keeps the centre 78 % then upscales back to 640×640.
SATELLITE_CROP_FACTOR=0.78

# ─── App ──────────────────────────────────────────────────────────────────────
# Set to "true" to enable verbose server-side logging
DEBUG_LOGGING=false
